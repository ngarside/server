[Container]
ContainerName=penpot_valkey
DropCapability=all
Image=ghcr.io/ngarside/valkey:9.0.4.754@sha256:93c06e59929ac7a612ea11e04f1f6d93b75b33a5b0987438ed52f1b3304a105f
Memory=4g
Network=penpot_internal.network:ip=10.4.0.2
NoNewPrivileges=true
ReadOnly=true
UserNS=auto:size=8

[Service]
CPUQuota=100%
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
