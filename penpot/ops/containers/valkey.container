[Container]
ContainerName=penpot_valkey
DropCapability=all
Image=ghcr.io/ngarside/valkey:9.0.4.687@sha256:d0aec2493bf8981c0a3a5ce2d1ce42f28ccfdaa29dc2f747f1265af93dbad007
Memory=4g
Network=penpot_internal.network:ip=10.4.0.2
NoNewPrivileges=true
ReadOnly=true
UserNS=auto:size=8

[Service]
CPUQuota=100%
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
