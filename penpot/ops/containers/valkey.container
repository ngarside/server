[Container]
ContainerName=penpot_valkey
DropCapability=all
Image=ghcr.io/ngarside/valkey:9.0.3.388@sha256:325ff3b8f87e34866bba12e98efdec7a367e2f57eb3d4b618d9af3ebf0e08c40
Memory=4g
Network=penpot_internal.network:ip=10.4.0.2
NoNewPrivileges=true
PodmanArgs=--cpus=1
ReadOnly=true
UserNS=auto:size=8

[Service]
Restart=always
TimeoutStartSec=9000

[Install]
WantedBy=default.target
