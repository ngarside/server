/*
	This is free and unencumbered software released into the public domain.

	This preset updates the version of headcheck as it is referenced in
	dockerfiles.

	- https://github.com/pixelatedlabs/headcheck
*/

{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"customManagers": [
		{
			"customType": "regex",
			"datasourceTemplate": "github-releases",
			"depNameTemplate": "pixelatedlabs/headcheck",
			"managerFilePatterns": ["**/*.dockerfile"],
			"matchStrings": [
				"\\n.*github.com/depName=(?<depName>\\w+/\\w+)/download/(?<currentValue>[^/]+)"
			]
		}
	],
	"packageRules": [
		{
			"commitMessageTopic": "{{{depName}}} tag",
			"matchDatasources": ["github-releases"],
			"matchManagers": ["custom.regex"]
		}
	]
}
