# This is free and unencumbered software released into the public domain.

[Unit]
After=crowdsec.container
Requires=crowdsec.container

[Container]
AddCapability=CAP_NET_BIND_SERVICE
ContainerName=caddy
DropCapability=all
Environment=HOME=/var/lib/caddy
GIDMap=0:8759
Image=ghcr.io/ngarside/caddy:2.11.2.415@sha256:6ffdc82e1b74e03c0617e753b3795cb9e2c8a2c80b583fdd58e477e9f072d22b
Memory=4g
Network=adguardhome.network:ip=10.2.0.3
Network=fossflow.network:ip=10.1.0.3
Network=memos.network:ip=10.6.0.3
Network=penpot_external.network:ip=10.3.0.2
Network=authentik_external.network:ip=10.8.0.2
Network=youtrack.network:ip=10.9.0.3
Network=outline_external.network:ip=10.10.0.5
Network=jellyfin.network:ip=10.11.0.3
Network=vaultwarden.network:ip=10.12.0.3
Network=cloudflared.network:ip=10.13.0.3
Network=gitea_server.network:ip=10.14.0.3
Network=chartdb.network:ip=10.16.0.3
Network=opencloud.network:ip=10.17.0.3
Network=excalidraw.network:ip=10.18.0.3
Network=whoami.network:ip=10.20.0.3
Network=grafana.network:ip=10.22.0.3
Network=bentopdf.network:ip=10.23.0.3
Network=victoria_logs.network:ip=10.24.0.5
Network=victoria_metrics.network:ip=10.25.0.5
Network=crowdsec.network:ip=10.26.0.3
NoNewPrivileges=true
PodmanArgs=--cpus=1
ReadOnly=true
Secret=machine_domain_root,type=env,target=MACHINE_DOMAIN_ROOT
Secret=cloudflare_api_token
Secret=crowdsec_bouncer_secret
UIDMap=0:8759
Volume=/etc/caddy:/etc/caddy:ro
Volume=/etc/pki/ca-trust/extracted/pem:/etc/pki/ca-trust/extracted/pem:ro
Volume=/var/data/caddy/logs:/var/log/caddy:z
Volume=/var/data/caddy/opt:/var/lib/caddy:U,Z

[Service]
Restart=always
TimeoutStartSec=9000
ExecStartPre=mkdir --parents /var/data/caddy/logs
ExecStartPre=mkdir --parents /var/data/caddy/opt
ExecStartPre=podman unshare chown --recursive 8759:8759 /var/data/caddy/logs
ExecStartPre=/bin/sleep 30

[Install]
WantedBy=default.target
