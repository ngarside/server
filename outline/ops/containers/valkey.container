[Container]
ContainerName=outline_valkey
DropCapability=all
Image=ghcr.io/ngarside/valkey:9.0.4.412@sha256:762b8a688f92ff533d7be3f392669dd9b3afcf0629c5e5fa8aa9b1ad66afb7b6
Memory=4g
Network=outline_internal.network:ip=10.19.0.4
NoNewPrivileges=true
ReadOnly=true
UserNS=auto:size=8

[Service]
CPUQuota=100%
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
