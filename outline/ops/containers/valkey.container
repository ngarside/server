[Container]
ContainerName=outline_valkey
DropCapability=all
Image=ghcr.io/ngarside/valkey:9.1.0.1052@sha256:b211959060729984a6d8f3008e3d733e404a4c34d2eb577442110d00b26c51c8
Memory=4g
Network=outline_internal.network:ip=10.19.0.4
NoNewPrivileges=true
ReadOnly=true
UserNS=auto:size=8

[Service]
CPUQuota=100%
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
