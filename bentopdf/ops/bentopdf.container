# This is free and unencumbered software released into the public domain.

[Container]
AddCapability=CAP_NET_BIND_SERVICE
ContainerName=bentopdf
CPUQuota=100%
DropCapability=all
Image=ghcr.io/ngarside/bentopdf:2.8.4.486@sha256:5afc0ec3c6616639629f94bb1c0f80b13bd40b388ecb94c0a65049783310f38a
Memory=512m
Network=bentopdf.network:ip=10.23.0.2
NoNewPrivileges=true
PidsLimit=64
ReadOnly=true
UserNS=auto:size=8

[Service]
Restart=always
TimeoutStartSec=9000

[Install]
WantedBy=default.target
